{
  "name": "Copilot SDK Task Tracker",
  "image": "mcr.microsoft.com/devcontainers/java:21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "GitHub.copilot"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic"
      }
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "gh extension install github/gh-copilot && ./mvnw dependency:resolve",
  "remoteUser": "vscode"
}
